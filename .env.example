# Obligatorio: clave de API de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-tu-clave-aqui

# Opcional: token de Hugging Face (necesario solo con --hf, https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: procesos MPI al ejecutar binarios traducidos (por defecto: 4)
MPI_PROCS=4

# Opcional: configuración de compilación Kokkos (si no tienes kokkos_config en PATH)
KOKKOS_CXX=g++
KOKKOS_CXXFLAGS=-std=c++20 -I/usr/local/include -DKokkos_ENABLE_OPENMP
KOKKOS_LDFLAGS=-L/usr/local/lib -lkokkosalgorithms -lkokkoscontainers -lkokkoscore -lkokkossimd -fopenmp -lm
